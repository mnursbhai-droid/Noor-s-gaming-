<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Noor S Gaming - Top Up & Tournament</title>
    <!-- Google Fonts for Modern Look -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Poppins', sans-serif;
        }
        body {
            background: #0f172a;
            color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 15px;
        }
        .container {
            background: #1e293b;
            border-radius: 20px;
            padding: 24px;
            width: 100%;
            max-width: 480px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 1px solid #334155;
        }
        .header {
            text-align: center;
            margin-bottom: 25px;
        }
        .header h1 {
            color: #38bdf8;
            font-size: 26px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .header p {
            color: #94a3b8;
            font-size: 13px;
            margin-top: 5px;
        }
        
        /* QR Code Section Styling */
        .qr-section {
            background: #0f172a;
            border: 2px dashed #38bdf8;
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            margin-bottom: 25px;
        }
        .qr-section p {
            font-size: 14px;
            color: #cbd5e1;
            margin-bottom: 10px;
            font-weight: 600;
        }
        /* placeholder QR - converts user uploaded image to base64 or displays dynamic text */
        .qr-image {
            width: 180px;
            height: 180px;
            background: white;
            margin: 0 auto 10px auto;
            padding: 5px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .qr-image img {
            max-width: 100%;
            max-height: 100%;
        }
        .qr-details {
            font-size: 13px;
            color: #38bdf8;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 20px;
        }
        label {
            display: block;
            margin-bottom: 8px;
            font-size: 13px;
            color: #94a3b8;
            font-weight: 600;
        }
        input, select {
            width: 100%;
            padding: 12px;
            background: #0f172a;
            border: 1px solid #475569;
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            outline: none;
            transition: 0.3s;
        }
        input:focus, select:focus {
            border-color: #38bdf8;
        }
        
        /* Screenshot Boxes */
        .screenshot-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
            background: #111827;
            padding: 15px;
            border-radius: 12px;
            margin-bottom: 25px;
            border: 1px solid #374151;
        }
        .screenshot-title {
            font-size: 14px;
            color: #f59e0b;
            font-weight: 600;
            margin-bottom: 5px;
        }
        .file-input-wrapper {
            background: #1f2937;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #4b5563;
        }
        .preview-box {
            margin-top: 8px;
            display: none;
            text-align: center;
        }
        .preview-box img {
            max-height: 100px;
            border-radius: 6px;
            border: 1px solid #4b5563;
        }

        .btn {
            width: 100%;
            padding: 15px;
            background: #25d366; /* WhatsApp Green */
            color: #fff;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 10px;
            transition: 0.3s;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.3);
        }
        .btn:hover {
            background: #128c7e;
            transform: translateY(-2px);
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h1>Noor S Gaming</h1>
        <p>⚡ Instant Diamond & Membership Top-Up ⚡</p>
    </div>

    <!-- eSewa QR Payment Section -->
    <div class="qr-section">
        <p>📲 Scan QR & Pay via eSewa</p>
        <div class="qr-image">
            <!-- QR image is source coded with your actual QR visual -->
            <img id="esewaQr" src="https://i.ibb.co/6803nMy7/esewa-qr.png" alt="eSewa QR Code" onerror="this.src='https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=9826776649'">
        </div>
        <div class="qr-details">Md. Lurslam: 9826776649</div>
    </div>

    <!-- Game UID -->
    <div class="form-group">
        <label for="gameUid">GAME UID (ID NUMBER)</label>
        <input type="text" id="gameUid" placeholder="Enter your Game UID" required>
    </div>

    <!-- Select Pack -->
    <div class="form-group">
        <label for="pack">SELECT DIAMONDS / MEMBERSHIP</label>
        <select id="pack" required>
            <option value="">-- Choose Option --</option>
            <optgroup label="💎 Diamonds (NPR / Points)">
                <option value="25 Diamonds (24 Points)">25 Diamonds (24 Points)</option>
                <option value="50 Diamonds (49 Points)">50 Diamonds (49 Points)</option>
                <option value="115 Diamonds (105 Points)">115 Diamonds (105 Points)</option>
                <option value="240 Diamonds (212 Points)">240 Diamonds (212 Points)</option>
                <option value="610 Diamonds (529 Points)">610 Diamonds (529 Points)</option>
                <option value="1090 Diamonds (949 Points)">1090 Diamonds (949 Points)</option>
                <option value="1240 Diamonds (1059 Points)">1240 Diamonds (1059 Points)</option>
                <option value="1595 Diamonds (1379 Points)">1595 Diamonds (1379 Points)</option>
                <option value="2090 Diamonds (1799 Points)">2090 Diamonds (1799 Points)</option>
                <option value="2530 Diamonds (2129 Points)">2530 Diamonds (2129 Points)</option>
                <option value="5060 Diamonds (4299 Points)">5060 Diamonds (4299 Points)</option>
                <option value="10120 Diamonds (8529 Points)">10120 Diamonds (8529 Points)</option>
            </optgroup>
            <optgroup label="🎫 Weekly / Monthly Membership">
                <option value="Weekly Lite (70 Points)">Weekly Lite (70 Points)</option>
                <option value="Weekly Lite 2x (140 Points)">Weekly Lite 2x (140 Points)</option>
                <option value="Weekly (215 Points)">Weekly (215 Points)</option>
                <option value="Weekly 2x (425 Points)">Weekly 2x (425 Points)</option>
                <option value="Monthly (1060 Points)">Monthly (1060 Points)</option>
                <option value="Monthly 2x (2100 Points)">Monthly 2x (2100 Points)</option>
            </optgroup>
            <optgroup label="📈 Level Up Pass">
                <option value="Level UP-6, 10, 15, 20, 25 (100 Points)">Level UP-6, 10, 15, 20, 25 (100 Points)</option>
                <option value="Level UP-30 (150 Points)">Level UP-30 (150 Points)</option>
                <option value="Level UP All (600 Points)">Level UP All (600 Points)</option>
            </optgroup>
        </select>
    </div>

    <!-- Screenshot Section -->
    <div class="screenshot-grid">
        <span class="screenshot-title">📸 Required Screenshots</span>
        
        <!-- 1. Payment Screenshot -->
        <div class="file-input-wrapper">
            <label style="color: #cbd5e1; margin-bottom: 4px;">1. Payment Screenshot *</label>
            <input type="file" id="payImg" accept="image/*" onchange="previewFile('payImg', 'payPrev')" required>
            <div class="preview-box" id="payPrev">
                <img src="" alt="Payment Preview">
            </div>
        </div>

        <!-- 2. Game Start Screenshot -->
        <div class="file-input-wrapper">
            <label style="color: #cbd5e1; margin-bottom: 4px;">2. Game Start Screen *</label>
            <input type="file" id="startImg" accept="image/*" onchange="previewFile('startImg', 'startPrev')" required>
            <div class="preview-box" id="startPrev">
                <img src="" alt="Start Preview">
            </div>
        </div>

        <!-- 3. Booyah Screenshot -->
        <div class="file-input-wrapper">
            <label style="color: #cbd5e1; margin-bottom: 4px;">3. Booyah / Win Screen *</label>
            <input type="file" id="winImg" accept="image/*" onchange="previewFile('winImg', 'winPrev')" required>
            <div class="preview-box" id="winPrev">
                <img src="" alt="Win Preview">
            </div>
        </div>
    </div>

    <!-- WhatsApp Button -->
    <button class="btn" onclick="sendToWhatsApp()">
        Send Order on WhatsApp 🚀
    </button>
</div>

<script>
    // Preview image on select
    function previewFile(inputId, previewId) {
        const file = document.getElementById(inputId).files[0];
        const previewContainer = document.getElementById(previewId);
        const previewImage = previewContainer.querySelector('img');
        
        if (file) {
            const reader = new FileReader();
            reader.onload = function() {
                previewImage.src = reader.result;
                previewContainer.style.display = 'block';
            }
            reader.readAsDataURL(file);
        }
    }

    // Process and send to WhatsApp
    function sendToWhatsApp() {
        const uid = document.getElementById('gameUid').value;
        const pack = document.getElementById('pack').value;
        
        const payFile = document.getElementById('payImg').files[0];
        const startFile = document.getElementById('startImg').files[0];
        const winFile = document.getElementById('winImg').files[0];

        if (!uid || !pack) {
            alert("Please enter UID and Select Pack!");
            return;
        }

        if (!payFile || !startFile || !winFile) {
            alert("Please upload all 3 screenshots (Payment, Game Start, and Booyah)!");
            return;
        }

        const myNumber = "9826776649"; // Apka Number

        // Beautiful Text Message for WhatsApp
        const message = `*🔥 NEW ORDER - NOOR S GAMING 🔥*\n\n` +
                        `👤 *Game UID:* ${uid}\n` +
                        `📦 *Selected Pack:* ${pack}\n\n` +
                        `📌 *Note:* Maine niche 3 screenshots attach kar diye hain:\n` +
                        `1. Payment Done Screenshot\n` +
                        `2. Game Start Screenshot\n` +
                        `3. Booyah / Winning Screenshot\n\n` +
                        `Please verify my order fast! ⚡`;

        const encodedMsg = encodeURIComponent(message);
        const whatsappUrl = `https://wa.me/${myNumber}?text=${encodedMsg}`;

        // External browser or WhatsApp me open hoga
        window.open(whatsappUrl, '_blank');
    }
</script>

</body>
</html>
